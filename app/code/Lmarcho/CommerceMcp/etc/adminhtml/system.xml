<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="lmarcho" translate="label" sortOrder="900">
            <label>Lmarcho</label>
        </tab>
        <section id="commerce_mcp" translate="label" sortOrder="20"
                 showInDefault="1" showInWebsite="0" showInStore="0">
            <label>Commerce MCP</label>
            <tab>lmarcho</tab>
            <resource>Lmarcho_CommerceMcp::config</resource>
            <group id="general" translate="label" sortOrder="10"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>General</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Enable MCP Endpoint</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Disabled by default. Enable only after allowed store codes and MCP clients are configured.</comment>
                </field>
                <field id="max_request_bytes" translate="label comment" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Maximum Request Size (bytes)</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                </field>
                <field id="max_response_bytes" translate="label comment" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Maximum Response Size (bytes)</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                </field>
                <field id="allowed_store_codes" translate="label comment" type="text" sortOrder="40"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Allowed Store Codes</label>
                    <comment>Comma-separated active storefront codes. The admin store is never allowed.</comment>
                </field>
                <field id="max_skus_per_request" translate="label comment" type="text" sortOrder="50"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Maximum SKUs Per Request</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                </field>
                <field id="max_gallery_images" translate="label comment" type="text" sortOrder="60"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Maximum Gallery Images Per Product</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                </field>
                <field id="max_variants_per_product" translate="label comment" type="text" sortOrder="70"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Maximum Variants Per Product</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                </field>
                <field id="variant_image_fallback_enabled" translate="label comment" type="select"
                       sortOrder="80" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Fallback to Parent Variant Image</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="max_search_results" translate="label comment" type="text" sortOrder="90"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Maximum Search Results</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                </field>
                <field id="max_related_products" translate="label comment" type="text" sortOrder="100"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Maximum Related Products Per Link Type</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                </field>
                <field id="max_promotions" translate="label comment" type="text" sortOrder="110"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Maximum Promotions Per Request</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                </field>
                <field id="public_coupon_codes" translate="label comment" type="textarea" sortOrder="120"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Public Chat Coupon Codes</label>
                    <comment>Comma-separated coupon codes that are approved for MCP chatbot display.</comment>
                </field>
                <field id="customer_assertion_lifetime_seconds" translate="label comment" type="text"
                       sortOrder="130" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Customer Assertion Lifetime (seconds)</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                    <comment>Clamped by the module to 60 through 300 seconds.</comment>
                </field>
                <field id="customer_assertion_signing_key" translate="label comment" type="obscure"
                       sortOrder="140" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Customer Assertion Signing Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment>Optional advanced setting for signing short-lived customer order assertions. Leave empty unless you want a dedicated HMAC secret; Magento's crypt key is used by default.</comment>
                </field>
                <field id="rate_limit_per_minute" translate="label comment" type="text" sortOrder="150"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Request Rate Limit Per Minute</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                </field>
                <field id="order_status_rate_limit_per_minute" translate="label comment" type="text"
                       sortOrder="160" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Order Status Rate Limit Per Minute</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                </field>
                <field id="tracking_url_templates" translate="label comment" type="textarea" sortOrder="170"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Tracking URL Templates</label>
                    <comment>One HTTPS template per line: carrier_code=https://carrier.example/track/{tracking_number}</comment>
                </field>
            </group>
            <group id="clients" translate="label" sortOrder="20"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Access Tokens</label>
                <field id="generate_token" translate="label comment" type="button" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Generate Client Token</label>
                    <frontend_model>Lmarcho\CommerceMcp\Block\Adminhtml\System\Config\GenerateToken</frontend_model>
                    <comment>Creates a named read-only MCP client and displays the token once. Store it securely.</comment>
                </field>
            </group>
        </section>
    </system>
</config>
