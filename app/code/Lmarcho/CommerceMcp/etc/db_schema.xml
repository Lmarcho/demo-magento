<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="lmarcho_commerce_mcp_role" resource="default" engine="innodb"
           comment="Commerce MCP Roles">
        <column xsi:type="int" name="role_id" unsigned="true" nullable="false"
                identity="true" comment="Role ID"/>
        <column xsi:type="varchar" name="name" nullable="false" length="128"
                comment="Role Name"/>
        <column xsi:type="timestamp" name="created_at" nullable="false"
                default="CURRENT_TIMESTAMP" on_update="false" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="role_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="LMARCHO_COMMERCE_MCP_ROLE_NAME">
            <column name="name"/>
        </constraint>
    </table>

    <table name="lmarcho_commerce_mcp_role_tool" resource="default" engine="innodb"
           comment="Commerce MCP Role Tools">
        <column xsi:type="int" name="role_tool_id" unsigned="true" nullable="false"
                identity="true" comment="Role Tool ID"/>
        <column xsi:type="int" name="role_id" unsigned="true" nullable="false"
                comment="Role ID"/>
        <column xsi:type="varchar" name="tool_name" nullable="false" length="64"
                comment="Tool Name"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="role_tool_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="LMARCHO_COMMERCE_MCP_ROLE_TOOL_ROLE"
                    table="lmarcho_commerce_mcp_role_tool" column="role_id"
                    referenceTable="lmarcho_commerce_mcp_role" referenceColumn="role_id"
                    onDelete="CASCADE"/>
        <constraint xsi:type="unique" referenceId="LMARCHO_COMMERCE_MCP_ROLE_TOOL_UNIQUE">
            <column name="role_id"/>
            <column name="tool_name"/>
        </constraint>
    </table>

    <table name="lmarcho_commerce_mcp_client" resource="default" engine="innodb"
           comment="Commerce MCP Clients">
        <column xsi:type="int" name="client_id" unsigned="true" nullable="false"
                identity="true" comment="Client ID"/>
        <column xsi:type="varchar" name="name" nullable="false" length="128"
                comment="Client Name"/>
        <column xsi:type="int" name="role_id" unsigned="true" nullable="false"
                comment="Role ID"/>
        <column xsi:type="smallint" name="is_active" unsigned="true" nullable="false"
                default="1" comment="Is Active"/>
        <column xsi:type="timestamp" name="created_at" nullable="false"
                default="CURRENT_TIMESTAMP" on_update="false" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" nullable="false"
                default="CURRENT_TIMESTAMP" on_update="true" comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="client_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="LMARCHO_COMMERCE_MCP_CLIENT_NAME">
            <column name="name"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="LMARCHO_COMMERCE_MCP_CLIENT_ROLE"
                    table="lmarcho_commerce_mcp_client" column="role_id"
                    referenceTable="lmarcho_commerce_mcp_role" referenceColumn="role_id"
                    onDelete="NO ACTION"/>
    </table>

    <table name="lmarcho_commerce_mcp_access_token" resource="default" engine="innodb"
           comment="Commerce MCP Access Tokens">
        <column xsi:type="int" name="token_id" unsigned="true" nullable="false"
                identity="true" comment="Token ID"/>
        <column xsi:type="int" name="client_id" unsigned="true" nullable="false"
                comment="Client ID"/>
        <column xsi:type="char" name="token_hash" nullable="false" length="64"
                comment="SHA-256 Token Hash"/>
        <column xsi:type="timestamp" name="expires_at" nullable="true"
                comment="Expires At"/>
        <column xsi:type="timestamp" name="last_used_at" nullable="true"
                comment="Last Used At"/>
        <column xsi:type="timestamp" name="revoked_at" nullable="true"
                comment="Revoked At"/>
        <column xsi:type="timestamp" name="created_at" nullable="false"
                default="CURRENT_TIMESTAMP" on_update="false" comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="token_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="LMARCHO_COMMERCE_MCP_TOKEN_HASH">
            <column name="token_hash"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="LMARCHO_COMMERCE_MCP_TOKEN_CLIENT"
                    table="lmarcho_commerce_mcp_access_token" column="client_id"
                    referenceTable="lmarcho_commerce_mcp_client" referenceColumn="client_id"
                    onDelete="CASCADE"/>
    </table>
</schema>
