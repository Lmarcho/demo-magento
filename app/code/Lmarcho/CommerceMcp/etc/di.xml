<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="Lmarcho\CommerceMcp\Api\AuthenticationServiceInterface"
                type="Lmarcho\CommerceMcp\Model\Authentication\AuthenticationService"/>
    <preference for="Lmarcho\CommerceMcp\Api\StoreContextResolverInterface"
                type="Lmarcho\CommerceMcp\Model\Store\StoreContextResolver"/>
    <preference for="Lmarcho\CommerceMcp\Api\ProductHydratorInterface"
                type="Lmarcho\CommerceMcp\Model\Product\ProductHydrator"/>
    <preference for="Lmarcho\CommerceMcp\Api\ProductVariantResolverInterface"
                type="Lmarcho\CommerceMcp\Model\Product\VariantResolver"/>
    <preference for="Lmarcho\CommerceMcp\Api\ProductVariantServiceInterface"
                type="Lmarcho\CommerceMcp\Model\Product\ProductVariantService"/>
    <preference for="Lmarcho\CommerceMcp\Api\ProductSearchServiceInterface"
                type="Lmarcho\CommerceMcp\Model\Product\ProductSearchService"/>
    <preference for="Lmarcho\CommerceMcp\Api\CategoryProductServiceInterface"
                type="Lmarcho\CommerceMcp\Model\Product\CategoryProductService"/>
    <preference for="Lmarcho\CommerceMcp\Api\RelatedProductServiceInterface"
                type="Lmarcho\CommerceMcp\Model\Product\RelatedProductService"/>
    <preference for="Lmarcho\CommerceMcp\Api\PromotionServiceInterface"
                type="Lmarcho\CommerceMcp\Model\Promotion\PromotionService"/>
    <preference for="Lmarcho\CommerceMcp\Api\CustomerAssertionServiceInterface"
                type="Lmarcho\CommerceMcp\Model\Authentication\CustomerAssertionService"/>
    <preference for="Lmarcho\CommerceMcp\Api\OrderStatusServiceInterface"
                type="Lmarcho\CommerceMcp\Model\Order\OrderStatusService"/>
    <preference for="Lmarcho\CommerceMcp\Api\CustomerCartServiceInterface"
                type="Lmarcho\CommerceMcp\Model\Customer\CustomerCartService"/>
    <preference for="Lmarcho\CommerceMcp\Api\CustomerPurchaseHistoryServiceInterface"
                type="Lmarcho\CommerceMcp\Model\Customer\CustomerPurchaseHistoryService"/>

    <type name="Lmarcho\CommerceMcp\Model\Mcp\ToolRegistry">
        <arguments>
            <argument name="implementedTools" xsi:type="array">
                <item name="get_store_context"
                      xsi:type="object">Lmarcho\CommerceMcp\Model\Tool\GetStoreContext</item>
                <item name="get_products_live"
                      xsi:type="object">Lmarcho\CommerceMcp\Model\Tool\GetProductsLive</item>
                <item name="search_products_live"
                      xsi:type="object">Lmarcho\CommerceMcp\Model\Tool\SearchProductsLive</item>
                <item name="get_category_products"
                      xsi:type="object">Lmarcho\CommerceMcp\Model\Tool\GetCategoryProducts</item>
                <item name="get_product_variants"
                      xsi:type="object">Lmarcho\CommerceMcp\Model\Tool\GetProductVariants</item>
                <item name="get_related_products"
                      xsi:type="object">Lmarcho\CommerceMcp\Model\Tool\GetRelatedProducts</item>
                <item name="get_active_promotions"
                      xsi:type="object">Lmarcho\CommerceMcp\Model\Tool\GetActivePromotions</item>
                <item name="get_order_status"
                      xsi:type="object">Lmarcho\CommerceMcp\Model\Tool\GetOrderStatus</item>
                <item name="get_customer_cart"
                      xsi:type="object">Lmarcho\CommerceMcp\Model\Tool\GetCustomerCart</item>
                <item name="get_customer_purchase_history"
                      xsi:type="object">Lmarcho\CommerceMcp\Model\Tool\GetCustomerPurchaseHistory</item>
            </argument>
        </arguments>
    </type>

    <virtualType name="Lmarcho\CommerceMcp\Logger" type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">commerce_mcp</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">Lmarcho\CommerceMcp\LoggerHandler</item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="Lmarcho\CommerceMcp\LoggerHandler"
                 type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/commerce-mcp.log</argument>
        </arguments>
    </virtualType>

    <type name="Lmarcho\CommerceMcp\Controller\Index\Index">
        <arguments>
            <argument name="logger" xsi:type="object">Lmarcho\CommerceMcp\Logger</argument>
        </arguments>
    </type>
    <type name="Lmarcho\CommerceMcp\Model\Mcp\Server">
        <arguments>
            <argument name="logger" xsi:type="object">Lmarcho\CommerceMcp\Logger</argument>
        </arguments>
    </type>

    <type name="Magento\Framework\Console\CommandList">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="commerce_mcp_client_create"
                      xsi:type="object">Lmarcho\CommerceMcp\Console\Command\CreateClientCommand</item>
                <item name="commerce_mcp_token_rotate"
                      xsi:type="object">Lmarcho\CommerceMcp\Console\Command\RotateTokenCommand</item>
                <item name="commerce_mcp_client_revoke"
                      xsi:type="object">Lmarcho\CommerceMcp\Console\Command\RevokeClientCommand</item>
                <item name="commerce_mcp_tools_list"
                      xsi:type="object">Lmarcho\CommerceMcp\Console\Command\ListToolsCommand</item>
            </argument>
        </arguments>
    </type>
</config>
