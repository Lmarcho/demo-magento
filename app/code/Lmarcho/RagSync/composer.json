            "email": "dev@lmarcho.com",
            "homepage": "https://askrag.app"
        }
    ],
    "require": {
        "php": "~8.1.0 || ~8.2.0 || ~8.3.0",
        "magento/framework": ">=103.0 <104",
        "magento/module-catalog": ">=104.0 <105",
        "magento/module-configurable-product": ">=100.4 <101",
        "magento/module-cms": ">=104.0 <105",
        "magento/module-sales-rule": ">=101.0 <102",
        "magento/module-catalog-rule": ">=101.0 <102",
        "magento/module-cron": ">=100.4 <101",
        "magento/module-store": ">=101.1 <102",
        "magento/module-backend": ">=102.0 <103",
